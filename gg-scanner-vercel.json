{
  "functions": {
    "api/scan.js": {
      "maxDuration": 120
    },
    "api/write.js": {
      "maxDuration": 60
    },
    "api/debug.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ]
}
